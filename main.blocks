1</field></shadow></value></block></value><statement name="DO1"><block type="game_show_long_text" id="gW:X::[.bLhhnbfM)WIu"><field name="layout">DialogLayout.Full</field><value name="str"><shadow type="text" id="pBp!-J9^On-U:?0c5D}#"><field name="TEXT">Fact 2/10. The Westren Australian colony of Little Penguins has been reduced by 90% in the last 20 years.</field></shadow></value><next><block type="gameOver2" id="blu#0rVnU!d8Hw.(cLd("><value name="win"><shadow type="toggleWinLose" id="UF`3I_0B9CSRHNlyb{-."><field name="win">false</field></shadow></value></block></next></block></statement><value name="IF2"><shadow type="logic_boolean" id="g;:58g(?j~g;[f9:V2rS"><field name="BOOL">FALSE</field></shadow><block type="logic_compare" id="::%GALP]HXvd[Ydd1D;p"><field name="OP">EQ</field><value name="A"><shadow type="math_number" id="*xOM7V%xAD1r/4C1,^!5"><field name="NUM">0</field></shadow><block type="variables_get" id="Uk9U!udITPZtOPYW;wLf"><field name="VAR" id="bxKh3sk(:OiIHH~*Xyd$">Random</field></block></value><value name="B"><shadow type="math_number" id="AC5+#%@Ou)BAWj|2?F-c"><field name="NUM">2</field></shadow></value></block></value><statement name="DO2"><block type="game_show_long_text" id=":j1|*BSq,[2V;/T67-SC"><field name="layout">DialogLayout.Full</field><value name="str"><shadow type="text" id="GS{Q^.)0B!*1=t-,8PhC"><field name="TEXT">Fact 3/10. Each year at least 50 little penguins get tangled in littered fishing nets.</field></shadow></value><next><block type="gameOver2" id="m~ZiBvF18rD`r$kB)-jf"><value name="win"><shadow type="toggleWinLose" id="OP{{?GA@,`OoWumPPE76"><field name="win">false</field></shadow></value></block></next></block></statement><value name="IF3"><shadow type="logic_boolean" id="[%zcSRhdz;llFp6b3Kbe"><field name="BOOL">FALSE</field></shadow><block type="logic_compare" id="#G/,[V.X6C$J$PP^VQ.8"><field name="OP">EQ</field><value name="A"><shadow type="math_number" id="-Fa{;h/{hWObca8Oc]]3"><field name="NUM">0</field></shadow><block type="v