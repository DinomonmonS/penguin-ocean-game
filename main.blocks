`Vlz%"><field name="layout">DialogLayout.Full</field><value name="str"><shadow type="text" id=";5n$=[7iusaKJK#*8Fq,"><field name="TEXT">Fact 8/10. Climate change is altering ocean conditions and food availability, making it harder for penguins to find prey. </field></shadow></value><next><block type="gameOver2" id="9tdqz)6w=${/2rz2{:t:"><value name="win"><shadow type="toggleWinLose" id="~D3ev$;{OQO4qT|+8(KV"><field name="win">false</field></shadow></value></block></next></block></statement><value name="IF3"><shadow type="logic_boolean" id="CSZ-;d;e2ez-)5V(2`vp"><field name="BOOL">FALSE</field></shadow><block type="logic_compare" id="c!0%%|Jm%5dg`-Pcl%c9"><field name="OP">EQ</field><value name="A"><shadow type="math_number" id="G@6zQx@472jiu*Mq]T9,"><field name="NUM">0</field></shadow><block type="variables_get" id="A9IR`#b2(*8DhV.hUAxG"><field name="VAR" id="bxKh3sk(:OiIHH~*Xyd$">Random</field></block></value><value name="B"><shadow type="math_number" id="{sh8a{#eePOpTv:^Qw}a"><field name="NUM">3</field></shadow></value></block></value><statement name="DO3"><block type="game_show_long_text" id="3Zu(`F-uoXq4QCh-c^Mi"><field name="layout">DialogLayout.Full</field><value name="str"><shadow type="text" id="_V2R5gz]rY21Aw|$NwgD"><field name="TEXT">Fact 9/10.Boats and watercraft can strike penguins at sea, causing injuries or death in some colonies.</field></shadow></value><next><block type="gameOver2" id="!yO^JajH?0Q^/d1n59C="><value name="win"><shadow type="toggleWinLose" id="_C1B26{-Pww^HS.)gUcs"><field name="win">false</field></shadow></value></block></next></block></statement><value name="IF4"><shadow type="logic_boolean" id="TN[#^U@lp[?+ag$usS[p"><field name="BOOL">FALSE</field></shadow><block type="logic_compare" id="%u2nPgE*(UMaWA{d-[zi"><field name="OP">EQ</field><value name="A"><shadow type="math_number" id="}w{@z9CH=qx2KB+%CM,5"><field name="NUM">0</field></shadow><block type="variables_get" id="8D6Sy1R#]fnR}no;5[L+"><field name="VAR" id="bxKh3sk(:OiIHH~*Xyd$">